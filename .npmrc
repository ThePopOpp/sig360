# next-auth@5 beta declares a peerOptional on nodemailer@^7, but this project
# pins nodemailer@^8 for its own IMAP/SMTP email. The two never interact
# (next-auth's email provider isn't used), so tolerate the peer mismatch.
# Required for `npm ci` in clean CI/Docker builds (Coolify/Nixpacks) to resolve.
legacy-peer-deps=true
